#!/usr/bin/env bash
#
# JenAI one-key launcher.
#   1. Sources ROS2 (so /ros* tools can see the graph) if none is active yet
#   2. Ensures uv is on PATH
#   3. Launches JenAI through uv (auto-syncs the project venv)
#
# Any arguments are passed straight through, e.g.:
#   jenai            # launch the TUI
#   jenai doctor     # environment health check
#   jenai web        # WebUI dashboard
#
# Override the project location with:  JENAI_DIR=/path/to/JenAI jenai
#
# API keys: JenAI itself loads ~/.config/jenai/.env (next to config.toml) at
# startup, so no env handling is needed here. Override with JENAI_ENV_FILE.

JENAI_DIR="${JENAI_DIR:-$HOME/JenAI}"
ROS_SETUP="${ROS_SETUP:-/opt/ros/jazzy/setup.bash}"

# 1) Source ROS2 only when no ROS environment is fully active: ROS_DISTRO unset,
#    or `ros2` missing from PATH (a partial/leaked env — ROS_DISTRO set but PATH
#    reset happens under some IDE/tmux/uv setups). If a different distro is
#    already sourced and working, we respect it: layering a second distro on top
#    breaks RMW/library resolution.
#    ROS setup scripts reference unbound variables, so we do NOT use `set -u`.
if [ -f "$ROS_SETUP" ] && { [ -z "${ROS_DISTRO:-}" ] || ! command -v ros2 >/dev/null 2>&1; }; then
    # shellcheck disable=SC1090
    source "$ROS_SETUP"
fi

# 2) Make sure uv (installed under ~/.local/bin) is reachable.
export PATH="$HOME/.local/bin:$PATH"

if ! command -v uv >/dev/null 2>&1; then
    echo "jenai: 'uv' was not found on PATH. Install uv or add it to PATH." >&2
    exit 127
fi

if [ ! -f "$JENAI_DIR/pyproject.toml" ]; then
    echo "jenai: JenAI project not found at '$JENAI_DIR'. Set JENAI_DIR to override." >&2
    exit 1
fi

# 3) Launch. `uv run` resolves JenAI from the project's own venv (which takes
#    PATH precedence), so this never recurses back into this wrapper.
exec uv run --project "$JENAI_DIR" JenAI "$@"
